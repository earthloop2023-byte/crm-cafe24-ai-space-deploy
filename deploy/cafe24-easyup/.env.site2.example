NODE_ENV=production
PORT=5002
DATABASE_URL=postgres://crm_site2:REPLACE_SITE2_DB_PASSWORD@127.0.0.1:5432/crmdb_site2
SESSION_SECRET=replace-with-strong-random-secret-site2

TRUST_PROXY=1
SESSION_COOKIE_NAME=crm_site2.sid
SESSION_COOKIE_SECURE=auto
SESSION_COOKIE_SAMESITE=lax
SESSION_TIMEOUT_DEFAULT_MINUTES=30
SESSION_PRUNE_INTERVAL_SECONDS=900

DB_BACKUP_DIR=/opt/crm/site2/backups/db
DB_BACKUP_RETENTION=30
