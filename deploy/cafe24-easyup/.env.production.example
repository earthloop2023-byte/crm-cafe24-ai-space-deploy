NODE_ENV=production
PORT=5001
DATABASE_URL=postgres://crm:crm@127.0.0.1:5432/crmdb
SESSION_SECRET=replace-with-strong-random-secret

# Session and proxy settings
TRUST_PROXY=1
SESSION_COOKIE_NAME=crm.sid
SESSION_COOKIE_SECURE=auto
SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_DOMAIN=example.com
SESSION_TIMEOUT_DEFAULT_MINUTES=30
SESSION_PRUNE_INTERVAL_SECONDS=900

# Optional backup settings
DB_BACKUP_DIR=/opt/crm/backups/db
DB_BACKUP_RETENTION=30
# PG_DUMP_BIN=/usr/bin/pg_dump
# PG_RESTORE_BIN=/usr/bin/pg_restore
