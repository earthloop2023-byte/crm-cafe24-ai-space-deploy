NODE_ENV=production
PORT=5001
DATABASE_URL=postgres://crm_site1:REPLACE_SITE1_DB_PASSWORD@127.0.0.1:5432/crmdb_site1
SESSION_SECRET=replace-with-strong-random-secret-site1

TRUST_PROXY=1
SESSION_COOKIE_NAME=crm_site1.sid
SESSION_COOKIE_SECURE=auto
SESSION_COOKIE_SAMESITE=lax
SESSION_TIMEOUT_DEFAULT_MINUTES=30
SESSION_PRUNE_INTERVAL_SECONDS=900

DB_BACKUP_DIR=/opt/crm/site1/backups/db
DB_BACKUP_RETENTION=30
